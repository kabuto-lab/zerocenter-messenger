# Rust
/target/
**/*.rs.bk
# NOTE: Cargo.lock is committed for binary crates (reproducible builds).

# Tauri
icons/*.svg
icons/*.png
icons/*.icns
icons/*.ico
# …but keep the placeholder ICO so `cargo build --features gui` succeeds
# on a fresh clone. Replace with a real branded icon if you ship a build.
!icons/icon.ico

# Tauri build script writes generated capability schemas here; regenerated
# on every build with `--features gui` and not meant to be committed.
gen/

# Development
*.log
*.db
*.db-shm
*.db-wal

# Environment
.env
.env.local

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Data (local test profiles)
data/

# Secrets — never commit identity keys
identity.json
**/identity.json

# Build staging dir for the friend ZIP (contents go into release/ME55-windows.zip)
dist-friend/
