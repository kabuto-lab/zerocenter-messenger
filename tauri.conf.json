{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ME55 Messenger",
  "version": "0.1.0",
  "identifier": "com.ME55.messenger",
  "build": {
    "frontendDist": "dist",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "",
    "beforeDevCommand": ""
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "ME55 Messenger",
        "width": 1100,
        "height": 700,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "category": "SocialNetworking",
    "shortDescription": "ME55 Messenger",
    "longDescription": "Censorship-Resistant, Zero-Trust, Leaderless P2P Messenger",
    "copyright": "",
    "icon": [],
    "resources": [],
    "externalBin": []
  }
}
